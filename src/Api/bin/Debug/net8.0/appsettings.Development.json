{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RideSharing": "Debug",
      "StackExchange.Redis": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5433;Database=ride_sharing;Username=devuser;Password=devpass;",
    "Redis": "localhost:6380",
    "Kafka": "localhost:9093"
  },
  "Authentication": {
    "Authority": "https://localhost:7001",
    "Audience": "ride-sharing-api",
    "DisableAuthentication": true
  },
  "Jwt": {
    "Authority": "https://localhost:7001",
    "ValidateAudience": false,
    "ValidateLifetime": false,
    "ValidateIssuerSigningKey": false
  },
  "Resilience": {
    "DefaultMaxAttempts": 3,
    "DefaultInitialDelayMs": 100,
    "DefaultMaxDelayMs": 2000,
    "DefaultJitterMs": 100,
    "PostgreSqlFailureThreshold": 5,
    "PostgreSqlCooldownSeconds": 30
  },
  "RateLimit": {
    "Enabled": true,
    "DefaultMaxRequestsPerMinute": 60
  },
  "Swagger": {
    "Enabled": true,
    "RoutePrefix": "swagger"
  },
  "ASPNETCORE_ENVIRONMENT": "Development"
}
